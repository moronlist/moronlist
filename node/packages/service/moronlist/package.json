{
  "name": "service-moronlist",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "MoronList collaborative block list REST API server",
  "main": "dist/bin/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/bin/server.ts",
    "start": "node dist/bin/server.js",
    "test": "NODE_OPTIONS='--import tsx' mocha tests/index.ts --timeout 60000",
    "test:build": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tinqerjs/better-sqlite3-adapter": "0.0.26",
    "@tinqerjs/tinqer": "0.0.26",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "moronlist-db": "*",
    "logger": "*",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mocha": "^10.0.10",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "chai": "^5.1.2",
    "mocha": "^10.8.2",
    "supertest": "^7.0.0",
    "test-utils": "*",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
