# =============================================================================
# Docker Host Path Variables (for volume mounts in production)
# These tell docker-compose where to find data on the HOST machine
# Leave empty for local development (not used outside Docker)
# =============================================================================

# Persona
PERSONA_DATA_HOST_DIR=
PERSONA_LOG_HOST_DIR=

# MoronList
MORONLIST_DATA_HOST_DIR=
MORONLIST_LOG_HOST_DIR=

# =============================================================================
# Common/Shared Configuration
# =============================================================================

# Logging
LOG_LEVEL=debug

# Environment
NODE_ENV=development

# Cookie Domain for shared auth cookies
COOKIE_DOMAIN=localhost

# Root Users - comma-separated emails that get ROOT role on signup
ROOT_USER_EMAILS=

# =============================================================================
# Persona Service (Authentication)
# =============================================================================

# Server Configuration (REQUIRED)
PERSONA_SERVER_HOST=0.0.0.0
PERSONA_SERVER_PORT=4005
PERSONA_SERVER_PUBLIC_URL=http://localhost:4005

# Data Directory (REQUIRED) - SQLite database stored here as persona.db
PERSONA_DATA_DIR=./data/persona/db

# Logging
PERSONA_LOG_FILE_DIR=./data/persona/logs

# JWT & Security (REQUIRED - shared across all services via Persona)
PERSONA_JWT_SECRET=
PERSONA_SESSION_SECRET=

# Tenant Configuration (single tenant mode for MoronList)
PERSONA_TENANT_MODE=single
PERSONA_TENANTS=moronlist

# Google OAuth (OIDC) - optional, leave empty to disable
PERSONA_GOOGLE_CLIENT_ID=
PERSONA_GOOGLE_CLIENT_SECRET=
PERSONA_GOOGLE_REDIRECT_URI=http://localhost:4005/auth/google/callback

# CORS Origins (comma-separated list of allowed origins)
PERSONA_CORS_ORIGINS=http://localhost:3000

# Cookie Domain (set to .moronlist.com in production for cross-subdomain cookies)
PERSONA_COOKIE_DOMAIN=

# Internal API Secret (REQUIRED - for service-to-service calls)
PERSONA_INTERNAL_SECRET=

# =============================================================================
# MoronList Service
# =============================================================================

# Server Configuration (REQUIRED)
MORONLIST_SERVER_HOST=0.0.0.0
MORONLIST_SERVER_PORT=4000
MORONLIST_PUBLIC_URL=http://localhost:4000

# Data Directory (REQUIRED) - SQLite database stored here as moronlist.db
MORONLIST_DATA_DIR=./data/moronlist/db

# Logging
MORONLIST_LOG_FILE_DIR=./data/moronlist/logs

# Database
MORONLIST_DB_TYPE=sqlite

# Persona Service URL (REQUIRED - for internal API calls via Docker network)
PERSONA_URL=http://persona-server:4005

# CORS Origins
MORONLIST_CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
